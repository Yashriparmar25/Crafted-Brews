rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      // Users can read/write only their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Order document rules
    match /orders/{orderId} {
      // Users can only read/write their own orders
      allow read, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Allow user to query their own orders list
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
